{
  "manifest_version": 3,
  "name": "AirPlay Simulator & Enabler",
  "version": "1.1",
  "description": "Adds an AirPlay-style button to HTML5 videos on any webpage to trigger native casting or open video stream.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AirPlay Simulator"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
